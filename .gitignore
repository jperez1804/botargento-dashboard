# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage
/test-results
/playwright-report
.playwright-dev-server.log

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# python (used by scripts/build-walkthrough-deck.py)
__pycache__/
*.pyc

# office lock files (PowerPoint / Word create these while a doc is open)
~$*

# Generated walkthrough decks — rebuild via scripts/build-walkthrough-deck.py.
# The brand assets and the script ARE committed, so anyone can regenerate.
/docs/dashboard-walkthrough*.pptx

# Screenshots from the live dashboard — may contain real contact data.
# Capture locally; do not commit.
/docs/screenshots/
