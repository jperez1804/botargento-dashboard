# Default: detect text files and store them with LF endings in the repo.
# Working trees on Windows still get CRLF (or stay LF on Linux/macOS) per
# the user's core.autocrlf, but the canonical bytes in the repo are LF.
* text=auto eol=lf

# Source code — explicit so unusual extensions are still treated as text.
*.ts text eol=lf
*.tsx text eol=lf
*.js text eol=lf
*.jsx text eol=lf
*.mjs text eol=lf
*.cjs text eol=lf
*.json text eol=lf
*.jsonc text eol=lf
*.yml text eol=lf
*.yaml text eol=lf
*.toml text eol=lf
*.css text eol=lf
*.scss text eol=lf
*.html text eol=lf
*.svg text eol=lf
*.md text eol=lf
*.sql text eol=lf
*.sh text eol=lf
*.py text eol=lf
*.txt text eol=lf
.env.example text eol=lf
.gitignore text eol=lf
.gitattributes text eol=lf
.editorconfig text eol=lf
.npmrc text eol=lf
.nvmrc text eol=lf
Dockerfile text eol=lf
*.dockerfile text eol=lf

# Windows-only scripts must keep CRLF to run from cmd.exe / PowerShell.
*.bat text eol=crlf
*.cmd text eol=crlf
*.ps1 text eol=crlf

# Binaries — never normalize, never diff as text.
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.webp binary
*.ico binary
*.pdf binary
*.pptx binary
*.docx binary
*.xlsx binary
*.zip binary
*.gz binary
*.tar binary
*.tgz binary
*.7z binary
*.woff binary
*.woff2 binary
*.ttf binary
*.otf binary
*.eot binary

# Lockfile — keep as text (LF), but no need to diff line-by-line.
pnpm-lock.yaml text eol=lf -diff
